{
  "name": "@oldfamilyrecipe/mcp-server",
  "version": "0.2.0",
  "description": "Official MCP server for Old Family Recipe — let Claude, ChatGPT, Cursor and any Model Context Protocol AI assistant save, search, and preserve family recipes (with provenance) in your cookbook. Includes OCR import of handwritten recipe cards, Sage AI chat, meal planning, and family sharing.",
  "main": "dist/index.js",
  "bin": {
    "oldfamilyrecipe-mcp": "dist/index.js"
  },
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "find src -name '*.test.ts' -print0 | xargs -0 tsx --test",
    "prepublishOnly": "npm run build"
  },
